  "specificProps": [
    "color",
    "speed",
    "direction",
    "scale",
    "opacity",
    "mouseInteractive"
  ],
  "tags": [
    "background",
    "animation",
    "react"
  ],
  "author": "veilosophy",
  "version": "1.0.0"
