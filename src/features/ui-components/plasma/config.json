{
  "id": "plasma",
  "name": "Plasma",
  "description": "Анимированный фоновый UI-компонент.",
  "category": "backgrounds",
  "main": "plasma.tsx",
  "props": [
    {
      "name": "color",
      "type": "string",
      "default": "#ff8844",
      "description": "color",
      "control": "text"
    },
    {
      "name": "speed",
      "type": "number",
      "default": 1,
      "description": "speed",
      "control": "number"
    },
    {
      "name": "direction",
      "type": "string",
      "default": "forward",
      "description": "direction",
      "control": "text"
    },
    {
      "name": "scale",
      "type": "number",
      "default": 1,
      "description": "scale",
      "control": "number"
    },
    {
      "name": "opacity",
      "type": "number",
      "default": 1,
      "description": "opacity",
      "control": "number"
    },
    {
      "name": "mouseInteractive",
      "type": "boolean",
      "default": false,
      "description": "mouseInteractive",
      "control": "boolean"
    }
