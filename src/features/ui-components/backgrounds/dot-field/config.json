      "control": "number"
    },
    {
      "name": "cursorRadius",
      "type": "number",
      "default": 500,
      "description": "cursorRadius",
      "control": "number"
    },
    {
      "name": "cursorForce",
      "type": "number",
      "default": 0.1,
      "description": "cursorForce",
      "control": "number"
    },
    {
      "name": "bulgeOnly",
      "type": "boolean",
      "default": true,
      "description": "bulgeOnly",
      "control": "boolean"
    },
    {
      "name": "bulgeStrength",
      "type": "number",
      "default": 67,
      "description": "bulgeStrength",
      "control": "number"
