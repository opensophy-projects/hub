  "specificProps": [
    "raysOrigin",
    "raysColor",
    "raysSpeed",
    "lightSpread",
    "rayLength",
    "pulsating",
    "fadeDistance",
    "saturation",
    "followMouse",
    "mouseInfluence",
    "noiseAmount",
    "distortion"
  ],
  "tags": [
    "background",
    "animation",
    "react"
  ],
  "author": "veilosophy",
  "version": "1.0.0"
