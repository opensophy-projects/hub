      "control": "number"
    },
    {
      "name": "noiseAmount",
      "type": "number",
      "default": 0,
      "description": "noiseAmount",
      "control": "number"
    },
    {
      "name": "distortion",
      "type": "number",
      "default": 0,
      "description": "distortion",
      "control": "number"
    }
