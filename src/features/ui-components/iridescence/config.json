{
  "id": "iridescence",
  "name": "Iridescence",
  "description": "Анимированный фоновый UI-компонент.",
  "category": "backgrounds",
  "main": "iridescence.tsx",
  "props": [
    {
      "name": "color",
      "type": "array",
      "default": [
        1,
        1,
        1
      ],
      "description": "color",
      "control": "text"
    },
    {
      "name": "speed",
      "type": "number",
      "default": 1,
      "description": "speed",
      "control": "number"
    },
    {
      "name": "amplitude",
      "type": "number",
      "default": 0.1,
      "description": "amplitude",
      "control": "number"
    },
    {
      "name": "mouseReact",
      "type": "boolean",
      "default": true,
      "description": "mouseReact",
      "control": "boolean"
    }
  ],
  "specificProps": [
    "color",
    "speed",
    "amplitude",
    "mouseReact"
  ],
  "tags": [
    "background",
    "animation",
    "react"
  ],
  "author": "veilosophy",
  "version": "1.0.0"
}