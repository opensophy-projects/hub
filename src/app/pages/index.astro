---
import Layout from '@/app/layouts/Layout.astro';
import DocContent from '@/features/docs/components/DocContent';
import { getCustomPageBySlug } from '@/custom';
import CustomPageRenderer from '@/custom/CustomPageRenderer';
import fs from 'node:fs';
import path from 'node:path';
import { buildDocFromPath } from '../../../scripts/docUtils.mjs';
import { resolveCustomSlug } from '../../../scripts/customUtils.mjs';

export const prerender = true;

const docsDir       = path.join(process.cwd(), 'Docs');
const welcomeMdPath = path.join(docsDir, 'welcome.md');
let welcomeDoc = null;
if (fs.existsSync(welcomeMdPath)) {
  try {
    welcomeDoc = buildDocFromPath(welcomeMdPath, docsDir);
    welcomeDoc.id   = 'welcome';
    welcomeDoc.slug = '';
  } catch {
    welcomeDoc = null;
  }
}

const SITE_NAME = 'Opensophy';
const landingPage = getCustomPageBySlug('general');
const LANDING_DESCRIPTION = landingPage?.metadata.description || 'Opensophy — open-source проект для IT-специалистов и инициатива открытой философии в IT. Качественные и доступные знания, услуги, инструменты и решения по безопасности, разработке и инфраструктуре — в открытом доступе.';
const LANDING_KEYWORDS = landingPage?.metadata.keywords || 'opensophy, кибербезопасность, DevSecOps, linux, разработка, инструменты, туториалы, open source, IT, mTLS, SAST, DAST, SCA, zero trust, CI/CD';

const welcomeCustomSlug = resolveCustomSlug(welcomeDoc?.frontmatter?.custom);
const welcomeCustomPage = welcomeCustomSlug ? getCustomPageBySlug(welcomeCustomSlug) : null;
const useCustomWelcome = !!welcomeCustomPage;

const title       = useCustomWelcome ? (welcomeCustomPage?.metadata.title || SITE_NAME) : (welcomeDoc?.title       || SITE_NAME);
const description = useCustomWelcome ? (welcomeCustomPage?.metadata.description || LANDING_DESCRIPTION) : (welcomeDoc?.description || LANDING_DESCRIPTION);
const keywords    = useCustomWelcome ? (welcomeCustomPage?.metadata.keywords || LANDING_KEYWORDS) : (welcomeDoc?.keywords || '');
const lang        = useCustomWelcome ? (welcomeCustomPage?.metadata.lang || 'ru') : (welcomeDoc?.lang || 'ru');
---

<Layout
  title={title}
  description={description}
  url="/"
  type="website"
  keywords={keywords}
  robots="index, follow"
  lang={lang}
>
  {useCustomWelcome ? (
    <>
      <noscript>
        <main style="max-width: 980px; margin: 0 auto; padding: 2rem 1rem;">
        <h1>{title}</h1>
        <p>{description}</p>
        <p>Opensophy публикует открытые материалы, статьи, документацию и UI-компоненты для IT-специалистов.</p>
      </main>
      </noscript>
      <CustomPageRenderer client:only="react" slug={welcomeCustomSlug} />
    </>
  ) : welcomeDoc ? (
    <DocContent client:only="react" doc={welcomeDoc} />
  ) : (
    <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;">
      <p>Загрузка...</p>
    </div>
  )}
</Layout>
