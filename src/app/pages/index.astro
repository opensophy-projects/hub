---
import Layout from '@/app/layouts/Layout.astro';
import DocContent from '@/features/docs/components/DocContent';
import fs from 'node:fs';
import path from 'node:path';
import { buildDocFromPath } from '../../../scripts/docUtils.mjs';

const docsDir       = path.join(process.cwd(), 'Docs');
const welcomeMdPath = path.join(docsDir, 'welcome.md');

let welcomeDoc = null;
if (fs.existsSync(welcomeMdPath)) {
  welcomeDoc = buildDocFromPath(welcomeMdPath, docsDir);
  welcomeDoc.id   = 'welcome';
  welcomeDoc.slug = '';
}

// SEO defaults из глобального конфига
let globalSeo = { siteTitle: 'Hub — Opensophy', siteDescription: 'Hub проекта Opensophy.', keywords: '', siteLang: 'ru' };
try {
  const mod = await import('@/shared/data/seo');
  if (mod?.SEO_CONFIG) globalSeo = { ...globalSeo, ...mod.SEO_CONFIG };
} catch {}

const title       = welcomeDoc?.title       || globalSeo.siteTitle;
const description = welcomeDoc?.description || globalSeo.siteDescription;
const keywords    = welcomeDoc?.keywords    || globalSeo.keywords;
const lang        = welcomeDoc?.lang        || globalSeo.siteLang;
---

<Layout
  title={title}
  description={description}
  url="/"
  type="website"
  keywords={keywords}
  robots="index, follow"
  lang={lang}
>
  {welcomeDoc ? (
    <DocContent client:only="react" doc={welcomeDoc} />
  ) : (
    <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;">
      <p>Загрузка...</p>
    </div>
  )}
</Layout>