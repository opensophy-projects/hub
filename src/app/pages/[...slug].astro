---
import Layout from '@/app/layouts/Layout.astro';
import DocContent from '@/features/docs/components/DocContent';
import CategoryContent from '@/features/docs/components/CategoryContent';
import { customPages, getCustomPageBySlug } from '@/custom';
import type { CustomPageDefinition } from '@/custom/types';
import CustomPageRenderer from '@/custom/CustomPageRenderer';
import fs from 'node:fs';
import path from 'node:path';
import {
  scanDocsDirectoryRecursive,
  buildDocFromPath,
  buildCategoryPages,
} from '../../../scripts/docUtils.mjs';
import { resolveCustomSlug } from '../../../scripts/customUtils.mjs';

export const prerender = import.meta.env.DEV ? false : true;

interface CategoryPathItem { slug: string; title: string; icon: string | null; }
interface DocPage {
  id: string;
  title: string;
  slug: string;
  description: string;
  content?: string;
  typename?: string;
  categoryPath?: CategoryPathItem[];
  navSlug?: string;
  navTitle?: string;
  navIcon?: string;
  author?: string;
  date?: string;
  updated?: string;
  tags?: string[];
  lang?: string;
  keywords?: string;
  robots?: string;
  icon?: string;
  priority?: number;
  custom?: string;
  image?: string;
  frontmatter?: Record<string, string | undefined>;
}

type CategoryDoc = Omit<DocPage, 'content' | 'keywords' | 'robots'>;
interface CategoryPage {
  id: string;
  slug: string;
  title: string;
  description?: string;
  icon?: string | null;
  navSlug?: string;
  navTitle?: string;
  navIcon?: string;
  parentTitle?: string;
  docs: CategoryDoc[];
}

type PageProps =
  | { doc: DocPage; category?: never; customPage?: never }
  | { doc?: never; category: CategoryPage; customPage?: never }
  | { doc?: never; category?: never; customPage: CustomPageDefinition };

type StaticPath = { params: { slug: string }; props: PageProps };


export async function getStaticPaths() {
  const docsDir = path.join(process.cwd(), 'Docs');
  const allMdFiles = fs.existsSync(docsDir) ? scanDocsDirectoryRecursive(docsDir) : [];
  const seen = new Map<string, string>();
  const frontmatterCustomSlugs = new Set<string>();
  const docs: DocPage[] = [];
  const paths: StaticPath[] = [];

  for (const mdPath of allMdFiles) {
    const doc = buildDocFromPath(mdPath, docsDir) as DocPage;
    if (!doc.slug) continue;
    if (seen.has(doc.slug)) {
      console.warn(`[slug dedup] Duplicate slug "${doc.slug}", skipping ${mdPath}`);
      continue;
    }
    seen.set(doc.slug, mdPath);
    const customSlug = resolveCustomSlug(doc.frontmatter?.custom);
    if (customSlug === doc.slug) frontmatterCustomSlugs.add(customSlug);
    docs.push(doc);
    paths.push({ params: { slug: doc.slug }, props: { doc } });
  }
  const categories = buildCategoryPages(docs) as CategoryPage[];
  for (const category of categories) {
    if (seen.has(category.slug)) {
      console.warn(`[category dedup] Category slug "${category.slug}" conflicts with a document, skipping category page`);
      continue;
    }
    seen.set(category.slug, '<category>');
    paths.push({ params: { slug: category.slug }, props: { category } });
  }

  for (const customPage of customPages) {
    if (seen.has(customPage.slug)) {
      if (!frontmatterCustomSlugs.has(customPage.slug)) {
        console.warn(`[custom page dedup] Custom page slug "${customPage.slug}" conflicts with another page, skipping custom page from ${customPage.folderName}`);
      }
      continue;
    }
    seen.set(customPage.slug, `<custom:${customPage.folderName}>`);
    paths.push({ params: { slug: customPage.slug }, props: { customPage } });
  }

  return paths;
}

const { slug } = Astro.params;
const docsDir = path.join(process.cwd(), 'Docs');
let doc: DocPage | null = null;
let category: CategoryPage | null = null;
let customPage: CustomPageDefinition | null = null;

if (import.meta.env.DEV) {
  if (slug && fs.existsSync(docsDir)) {
    const allMdFiles = scanDocsDirectoryRecursive(docsDir);
    const docs: DocPage[] = [];
    for (const mdPath of allMdFiles) {
      try {
        const candidate = buildDocFromPath(mdPath, docsDir) as DocPage;
        docs.push(candidate);
        if (candidate.slug === slug) doc = candidate;
      } catch (e) {
        console.warn(`[slug] Failed to build doc from ${mdPath}:`, e);
      }
    }
    if (!doc) category = (buildCategoryPages(docs) as CategoryPage[]).find((candidate) => candidate.slug === slug) ?? null;
    if (!doc && !category) customPage = getCustomPageBySlug(slug);
  }
} else {
  const props = Astro.props as Partial<PageProps>;
  doc = props.doc ?? null;
  category = props.category ?? null;
  customPage = props.customPage ?? null;
}

const frontmatterCustomSlug = resolveCustomSlug(doc?.frontmatter?.custom);
const frontmatterCustomPage = frontmatterCustomSlug ? getCustomPageBySlug(frontmatterCustomSlug) : null;

if ((!doc && !category && !customPage) || !slug) return Astro.redirect('/404');

---

<Layout
  title={doc?.title ?? category?.title ?? customPage?.metadata.title}
  description={doc?.description ?? category?.description ?? customPage?.metadata.description}
  image={doc?.image ?? customPage?.metadata.image}
  url={`/${slug}/`}
  type={doc ? 'article' : (customPage?.metadata.type ?? 'website')}
  author={doc?.author ?? customPage?.metadata.author}
  date={doc?.date ?? customPage?.metadata.date}
  keywords={doc?.keywords ?? customPage?.metadata.keywords}
  robots={doc?.robots ?? customPage?.metadata.robots}
  lang={doc?.lang || customPage?.metadata.lang || 'ru'}
>
  {doc ? (
    <>
      {frontmatterCustomPage ? (
        <CustomPageRenderer client:load slug={frontmatterCustomSlug} />
      ) : (
        <DocContent client:load doc={doc} />
      )}
    </>
  ) : customPage ? (
    <>
      <CustomPageRenderer client:load slug={slug} />
    </>
  ) : (
    <>
      <CategoryContent client:load category={category} />
    </>
  )}
</Layout>