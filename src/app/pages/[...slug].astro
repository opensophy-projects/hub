---
import Layout from '@/app/layouts/Layout.astro';
import DocContent from '@/features/docs/components/DocContent';
import fs from 'node:fs';
import path from 'node:path';
import {
  scanDocsDirectoryRecursive,
  buildDocFromPath,
} from '../../../scripts/docUtils.mjs';

export async function getStaticPaths() {
  const docsDir = path.join(process.cwd(), 'Docs');

  if (!fs.existsSync(docsDir)) {
    console.warn('Docs directory not found');
    return [];
  }

  const allMdFiles = scanDocsDirectoryRecursive(docsDir);

  // FIX: deduplicate slugs before returning paths to Astro.
  // When two .md files resolve to the same slug, Astro throws a cryptic build
  // error. We warn early with both conflicting file paths and skip the duplicate.
  const seen = new Map<string, string>(); // slug → first mdPath that claimed it

  const paths: Array<{ params: { slug: string }; props: { doc: any } }> = [];

  for (const mdPath of allMdFiles) {
    // FIX: buildDocFromPath already calls getDocInfo internally — we no longer
    // need a separate getDocInfo call just to read the slug.
    const doc = buildDocFromPath(mdPath, docsDir);

    // welcome.md → slug '' → rendered by index.astro, skip here
    if (!doc.slug) continue;

    if (seen.has(doc.slug)) {
      console.warn(
        `[slug dedup] Duplicate slug "${doc.slug}" found:\n` +
        `  first:  ${seen.get(doc.slug)}\n` +
        `  second: ${mdPath}\n` +
        `  Skipping the second file.`
      );
      continue;
    }

    seen.set(doc.slug, mdPath);
    paths.push({
      params: { slug: doc.slug },
      props: { doc },
    });
  }

  return paths;
}

const { slug } = Astro.params;
const { doc } = Astro.props as { doc: any };

if (!doc || !slug) {
  return Astro.redirect('/404');
}
---

<Layout
  title={doc.title}
  description={doc.description}
  image={doc.image}
  url={`/${slug}`}
  type="article"
  author={doc.author}
  date={doc.date}
  keywords={doc.keywords}
  robots={doc.robots}
>
  <DocContent client:only="react" doc={doc} />
</Layout>