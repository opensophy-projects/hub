---
import Layout from '@/app/layouts/Layout.astro';
import DocContent from '@/features/docs/components/DocContent';
import fs from 'node:fs';
import path from 'node:path';
import {
  scanDocsDirectoryRecursive,
  buildDocFromPath,
} from '../../../scripts/docUtils.mjs';

export const prerender = import.meta.env.DEV ? false : true;

export async function getStaticPaths() {
  const docsDir = path.join(process.cwd(), 'Docs');
  if (!fs.existsSync(docsDir)) return [];

  const allMdFiles = scanDocsDirectoryRecursive(docsDir);
  const seen = new Map<string, string>();
  const paths: Array<{ params: { slug: string }; props: { doc: any } }> = [];

  for (const mdPath of allMdFiles) {
    const doc = buildDocFromPath(mdPath, docsDir);
    if (!doc.slug) continue;
    if (seen.has(doc.slug)) {
      console.warn(`[slug dedup] Duplicate slug "${doc.slug}", skipping ${mdPath}`);
      continue;
    }
    seen.set(doc.slug, mdPath);
    paths.push({ params: { slug: doc.slug }, props: { doc } });
  }
  return paths;
}

const { slug } = Astro.params;
const docsDir = path.join(process.cwd(), 'Docs');
let doc: any = null;

if (import.meta.env.DEV) {
  if (slug && fs.existsSync(docsDir)) {
    const allMdFiles = scanDocsDirectoryRecursive(docsDir);
    for (const mdPath of allMdFiles) {
      try {
        const candidate = buildDocFromPath(mdPath, docsDir);
        if (candidate.slug === slug) { doc = candidate; break; }
      } catch (e) {
        console.warn(`[slug] Failed to build doc from ${mdPath}:`, e);
      }
    }
  }
} else {
  doc = (Astro.props as any).doc ?? null;
}

if (!doc || !slug) return Astro.redirect('/404');
---

<Layout
  title={doc.title}
  description={doc.description}
  image={doc.image}
  url={`/${slug}/`}
  type="article"
  author={doc.author}
  date={doc.date}
  keywords={doc.keywords}
  robots={doc.robots}
  lang={doc.lang || 'ru'}
  preloadDocsManifest={true}
>
  <div id="doc-static-shell" style="min-height:100vh;background:#0a0a0a;color:#e8e8e8;">
    <main style="max-width: 980px; margin: 0 auto; padding: 2rem 1rem 4rem;">
      <header style="padding:1rem 0 2rem;border-bottom:1px solid rgba(255,255,255,0.12);margin-bottom:2rem;">
        <h1 style="font-size:clamp(1.8rem,5vw,3rem);line-height:1.15;margin:0 0 1rem;font-family:system-ui,-apple-system,sans-serif;">{doc.title}</h1>
        {doc.description && <p style="font-size:1rem;line-height:1.65;margin:0;color:rgba(255,255,255,0.72);">{doc.description}</p>}
      </header>
      <article set:html={doc.content ?? ''} />
    </main>
  </div>
  <noscript>
    <style>#doc-static-shell{display:block!important}</style>
  </noscript>
  <DocContent client:only="react" doc={doc} />
</Layout>
