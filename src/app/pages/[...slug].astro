---
import Layout from '@/app/layouts/Layout.astro';
import DocContent from '@/features/docs/components/DocContent';
import fs from 'node:fs';
import path from 'node:path';
import { scanDocsDirectoryRecursive, generateSlugFromPath, buildDocFromPath } from '../../../scripts/docUtils.mjs';

export async function getStaticPaths() {
  const docsDir = path.join(process.cwd(), 'Docs');

  if (!fs.existsSync(docsDir)) {
    console.warn('Docs directory not found');
    return [];
  }

  const allMdFiles = scanDocsDirectoryRecursive(docsDir);

  return allMdFiles
    .map((mdPath) => {
      const slug = generateSlugFromPath(mdPath, docsDir);
      if (!slug) return null;

      const doc = buildDocFromPath(mdPath, docsDir);

      return {
        params: { slug },
        props: { doc },
      };
    })
    .filter(Boolean);
}

const { slug } = Astro.params;
const { doc } = Astro.props as { doc: any };

if (!doc || !slug) {
  return Astro.redirect('/404');
}
---

<Layout
  title={doc.title}
  description={doc.description}
  url={`/${slug}`}
  type="article"
  author={doc.author}
  date={doc.date}
  keywords={doc.keywords}
  robots={doc.robots}
>
  <DocContent client:only="react" doc={doc} />
</Layout>