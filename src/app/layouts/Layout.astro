---
import '@/shared/styles/global.css';
import 'katex/dist/katex.min.css';
import { ThemeProvider } from '@/shared/contexts/ThemeContext';
import ErrorBoundary from '@/shared/components/ErrorBoundary';
import TopNavbar from '@/features/navigation/components/MobileNavbar';
import SearchWrapper from '@/features/navigation/components/SearchWrapper';

interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
  type?: 'website' | 'article';
  author?: string;
  date?: string;
  keywords?: string;
  robots?: string;
}

const {
  title,
  description = 'Hub - Opensophy',
  image,
  url = '/',
  type = 'website',
  author,
  date,
  keywords = 'opensophy, hub, documentation',
  robots = 'index, follow',
} = Astro.props;

const fullUrl = new URL(url, 'https://hub.opensophy.com').href;
const imageUrl = image
  ? new URL(image, 'https://hub.opensophy.com').href
  : 'https://hub.opensophy.com/og-image.png';
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Theme: must run before any paint to eliminate FOUC -->
    <script is:inline>
      (function () {
        var theme = localStorage.getItem('theme');
        if (!theme) theme = 'dark';
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
          document.documentElement.style.colorScheme = 'dark';
        } else {
          document.documentElement.classList.remove('dark');
          document.documentElement.style.colorScheme = 'light';
        }
      })();
    </script>

    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content={robots} />
    
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={fullUrl} />
    <meta property="og:image" content={imageUrl} />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    
    {type === 'article' && author && (
      <meta name="author" content={author} />
    )}
    
    {type === 'article' && date && (
      <>
        <meta property="article:published_time" content={new Date(date).toISOString()} />
        <meta property="article:modified_time" content={new Date(date).toISOString()} />
      </>
    )}
    
    <link rel="canonical" href={fullUrl} />
    <link rel="icon" href="/favicon.png" />
    
    <style is:global>
      @font-face {
        font-family: 'customfont';
        src: url('/customfont.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }

      :root {
        --font-sans: system-ui, -apple-system, sans-serif;
        --font-mono: ui-monospace, monospace;
        /* Sidebar width — matches the React component's w-80 = 20rem */
        --sidebar-width: 20rem;
      }

      html {
        font-family: var(--font-sans);
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        margin: 0;
        padding: 0;
        overflow-x: hidden;
      }

      /*
       * Pre-reserve the sidebar space BEFORE React hydrates.
       * This is the key fix: the sidebar placeholder occupies 20rem on desktop
       * so the main content never has to "jump" rightward when JS loads.
       *
       * The actual sidebar element is position:fixed so it doesn't affect
       * document flow — we use a pseudo-spacer on body instead.
       *
       * We apply margin-left directly to the document root so any
       * client:only island that renders <main> already has the correct offset.
       */
      @media (min-width: 768px) {
        /* Spacer so SSR content is already offset correctly */
        body {
          padding-left: var(--sidebar-width);
        }

        /*
         * Once React mounts and DocContent renders its own <main> with
         * margin-left: 20rem, we must remove the body padding to avoid double offset.
         * We detect hydration by presence of [data-doc-hydrated] attribute
         * which DocContent sets on mount.
         */
        body[data-doc-hydrated] {
          padding-left: 0;
        }
      }
    </style>

    <title>{title}</title>
  </head>
  <body>
    <ErrorBoundary>
      <ThemeProvider>
        <TopNavbar client:only="react" />
        <slot />
        <SearchWrapper client:only="react" />
      </ThemeProvider>
    </ErrorBoundary>

    <!-- Mark body as hydrated once JS runs, removes the SSR padding-left -->
    <script is:inline>
      // Set immediately on DOMContentLoaded — before React paints
      document.addEventListener('DOMContentLoaded', function() {
        // Small rAF delay so React's first paint happens before we toggle padding
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            document.body.setAttribute('data-doc-hydrated', 'true');
          });
        });
      });
    </script>
  </body>
</html>