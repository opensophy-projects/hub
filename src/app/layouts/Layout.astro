---
import '@/shared/styles/global.css';
import 'katex/dist/katex.min.css';
import { ClientRouter } from 'astro:transitions';
import { ThemeProvider } from '@/shared/contexts/ThemeContext';
import ErrorBoundary from '@/shared/components/ErrorBoundary';
import DevPanelLoader from '@/features/dev-panel/DevPanelLoader';

// SEO defaults — управляется через Dev Panel → вкладка "Сайт"
let SEO_CONFIG = {
  siteTitle:       'Hub — Opensophy',
  siteDescription: 'Hub проекта Opensophy.',
  siteUrl:         'https://hub.opensophy.com',
  siteLang:        'ru',
  siteAuthor:      'Opensophy',
  keywords:        'opensophy, hub, документация',
  metaRobots:      'index, follow',
  canonicalBase:   '',
  ogImage:         '/og-image.png',
  ogType:          'website',
  ogLocale:        'ru_RU',
  ogSiteName:      '',
  twitterCard:     'summary_large_image',
  twitterSite:     '',
  twitterCreator:  '',
  geoRegion:       '',
  geoPlacename:    '',
  geoPosition:     '',
  icbm:            '',
  themeColor:      '',
  colorScheme:     '',
  viewport:        'width=device-width, initial-scale=1.0',
  rating:          '',
  revisitAfter:    '',
  copyright:       '',
  googleVerify:    '',
  yandexVerify:    '',
  bingVerify:      '',
};

try {
  const mod = await import('@/shared/data/seo');
  if (mod?.SEO_CONFIG) SEO_CONFIG = { ...SEO_CONFIG, ...mod.SEO_CONFIG };
} catch {
  // seo.ts ещё не создан — используем дефолты выше
}

interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
  type?: 'website' | 'article';
  author?: string;
  date?: string;
  keywords?: string;
  robots?: string;
  lang?: string;
}

const {
  title       = SEO_CONFIG.siteTitle,
  description = SEO_CONFIG.siteDescription,
  image,
  url = '/',
  type = 'website',
  author,
  date,
  keywords = SEO_CONFIG.keywords,
  robots   = SEO_CONFIG.metaRobots,
  lang     = SEO_CONFIG.siteLang,
} = Astro.props;

const baseUrl  = SEO_CONFIG.siteUrl.replace(/\/$/, '');
const canonicalBase = (SEO_CONFIG.canonicalBase || SEO_CONFIG.siteUrl).replace(/\/$/, '');
const fullUrl  = new URL(url, baseUrl).href;
const canonicalUrl = new URL(url, canonicalBase).href;
const imageUrl = image
  ? new URL(image, baseUrl).href
  : new URL(SEO_CONFIG.ogImage, baseUrl).href;

const pageTitle = title === SEO_CONFIG.siteTitle
  ? title
  : `${title} — ${SEO_CONFIG.siteTitle}`;

const ogSiteName = SEO_CONFIG.ogSiteName || SEO_CONFIG.siteTitle;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content={SEO_CONFIG.viewport || 'width=device-width, initial-scale=1.0'} />

    <!-- Theme init (runs before paint) -->
    <script is:inline>
      (function () {
        var theme = localStorage.getItem('theme');
        if (!theme) theme = 'dark';
        var dark = theme !== 'light';
        if (dark) {
          document.documentElement.classList.add('dark');
          document.documentElement.style.colorScheme = 'dark';
        } else {
          document.documentElement.classList.remove('dark');
          document.documentElement.style.colorScheme = 'light';
        }
        document.documentElement.style.backgroundColor = dark ? '#0a0a0a' : '#E8E7E3';
      })();
    </script>

    <!-- SEO Core -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="robots" content={robots} />
    {(author || SEO_CONFIG.siteAuthor) && <meta name="author" content={author || SEO_CONFIG.siteAuthor} />}
    {SEO_CONFIG.copyright && <meta name="copyright" content={SEO_CONFIG.copyright} />}
    {SEO_CONFIG.rating && <meta name="rating" content={SEO_CONFIG.rating} />}
    {SEO_CONFIG.revisitAfter && <meta name="revisit-after" content={SEO_CONFIG.revisitAfter} />}
    {SEO_CONFIG.colorScheme && <meta name="color-scheme" content={SEO_CONFIG.colorScheme} />}
    {SEO_CONFIG.themeColor && <meta name="theme-color" content={SEO_CONFIG.themeColor} />}

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type"        content={type === 'article' ? 'article' : SEO_CONFIG.ogType} />
    <meta property="og:url"         content={fullUrl} />
    <meta property="og:image"       content={imageUrl} />
    <meta property="og:locale"      content={SEO_CONFIG.ogLocale} />
    <meta property="og:site_name"   content={ogSiteName} />

    <!-- Twitter / X -->
    <meta name="twitter:card"        content={SEO_CONFIG.twitterCard} />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={imageUrl} />
    {SEO_CONFIG.twitterSite    && <meta name="twitter:site"    content={SEO_CONFIG.twitterSite} />}
    {SEO_CONFIG.twitterCreator && <meta name="twitter:creator" content={SEO_CONFIG.twitterCreator} />}

    <!-- Article meta -->
    {type === 'article' && author && <meta name="author" content={author} />}
    {type === 'article' && date && (
      <>
        <meta property="article:published_time" content={new Date(date).toISOString()} />
        <meta property="article:modified_time"  content={new Date(date).toISOString()} />
      </>
    )}

    <!-- GEO / Геолокация -->
    {SEO_CONFIG.geoRegion    && <meta name="geo.region"    content={SEO_CONFIG.geoRegion} />}
    {SEO_CONFIG.geoPlacename && <meta name="geo.placename" content={SEO_CONFIG.geoPlacename} />}
    {SEO_CONFIG.geoPosition  && <meta name="geo.position"  content={SEO_CONFIG.geoPosition} />}
    {SEO_CONFIG.icbm         && <meta name="ICBM"          content={SEO_CONFIG.icbm} />}

    <!-- Search Engine Verification -->
    {SEO_CONFIG.googleVerify && <meta name="google-site-verification" content={SEO_CONFIG.googleVerify} />}
    {SEO_CONFIG.yandexVerify && <meta name="yandex-verification"      content={SEO_CONFIG.yandexVerify} />}
    {SEO_CONFIG.bingVerify   && <meta name="msvalidate.01"             content={SEO_CONFIG.bingVerify} />}

    <link rel="icon" href="/favicon.png" />

    <ClientRouter />

    <style is:global>
      @font-face {
        font-family: 'customfont';
        src: url('/customfont.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      :root {
        --font-sans: system-ui, -apple-system, sans-serif;
        --font-mono: ui-monospace, monospace;
      }
      html {
        font-family: var(--font-sans);
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      html:not(.dark) { background-color: #E8E7E3; }
      html.dark        { background-color: #0a0a0a; }
      body { margin: 0; padding: 0; overflow-x: hidden; }
    </style>
  </head>
  <body>
    <ErrorBoundary>
      <ThemeProvider>
        <slot />
      </ThemeProvider>
    </ErrorBoundary>

    <DevPanelLoader client:only="react" />

    <!-- Theme sync after SPA navigation -->
    <script is:inline>
      document.addEventListener('astro:after-swap', function () {
        var theme = localStorage.getItem('theme') || 'dark';
        var dark  = theme !== 'light';
        if (dark) {
          document.documentElement.classList.add('dark');
          document.documentElement.style.colorScheme = 'dark';
        } else {
          document.documentElement.classList.remove('dark');
          document.documentElement.style.colorScheme = 'light';
        }
        document.documentElement.style.backgroundColor = dark ? '#0a0a0a' : '#E8E7E3';
      });
    </script>
  </body>
</html>