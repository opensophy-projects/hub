---
import '@/shared/styles/global.css';
import 'katex/dist/katex.min.css';
import { ClientRouter } from 'astro:transitions';
import { ThemeProvider } from '@/shared/contexts/ThemeContext';
import ErrorBoundary from '@/shared/components/ErrorBoundary';
import DevPanelLoader from '@/features/dev-panel/DevPanelLoader';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
  type?: 'website' | 'article';
  author?: string;
  date?: string;
  updated?: string;
  keywords?: string;
  robots?: string;
  lang?: string;
}

const SITE = {
  name:        'Opensophy',
  description: 'Opensophy — open-source проект для IT-специалистов. Инструменты, туториалы и материалы по безопасности веб-приложений, DevSecOps, разработке и инфраструктуре — в открытом доступе.',
  url:         'https://opensophy.com',
  lang:        'ru',
  author:      'Opensophy',
  keywords:    'opensophy, опенсофи, opensophy.com, кибербезопасность, DevSecOps, devsecops инструменты, разработка devsecops, безопасность веб-приложений, SAST, DAST, SCA, статический анализ кода, аудит безопасности, open-source безопасность, IT-безопасность, пентест, vulnerability, уязвимости, CI/CD безопасность, разработка, туториалы, инфраструктура, безопасный код, secure coding, web security, application security, appsec',
  ogImage:     '/og-image.png',
  ogLocale:    'ru_RU',
  twitterCard: 'summary_large_image',
  twitterSite: '@opensophy',
  themeColor:  '#0a0a0a',
};

const {
  title       = SITE.name,
  description = SITE.description,
  image,
  url         = '/',
  type        = 'website',
  author      = SITE.author,
  date,
  updated,
  keywords    = SITE.keywords,
  robots      = 'index, follow',
  lang        = SITE.lang,
} = Astro.props;

const pageTitle    = title === SITE.name ? title : `${title} — ${SITE.name}`;
const canonicalUrl = new URL(url, SITE.url).href;
const imageUrl     = image ? new URL(image, SITE.url).href : new URL(SITE.ogImage, SITE.url).href;
const publishedISO = date    ? new Date(date).toISOString()    : undefined;
const updatedISO   = updated ? new Date(updated).toISOString() : publishedISO;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Theme: runs before paint, prevents flash -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem('theme') || 'dark';
        var d = t !== 'light';
        document.documentElement.classList.toggle('dark', d);
        document.documentElement.style.colorScheme = d ? 'dark' : 'light';
        document.documentElement.style.backgroundColor = d ? '#0a0a0a' : '#E8E7E3';
      })();
    </script>

    <!-- Primary SEO -->
    <title>{pageTitle}</title>
    <meta name="description"  content={description} />
    <meta name="keywords"     content={keywords} />
    <meta name="author"       content={author} />
    <meta name="robots"       content={robots} />
    <meta name="theme-color"  content={SITE.themeColor} />
    <meta name="color-scheme" content="dark light" />
    <link rel="canonical"     href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:site_name"    content={SITE.name} />
    <meta property="og:title"        content={title} />
    <meta property="og:description"  content={description} />
    <meta property="og:type"         content={type === 'article' ? 'article' : 'website'} />
    <meta property="og:url"          content={canonicalUrl} />
    <meta property="og:image"        content={imageUrl} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale"       content={SITE.ogLocale} />

    <!-- Twitter / X -->
    <meta name="twitter:card"        content={SITE.twitterCard} />
    <meta name="twitter:site"        content={SITE.twitterSite} />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={imageUrl} />

    <!-- Article-specific -->
    {type === 'article' && publishedISO && (
      <meta property="article:published_time" content={publishedISO} />
    )}
    {type === 'article' && updatedISO && (
      <meta property="article:modified_time" content={updatedISO} />
    )}
    {type === 'article' && (
      <meta property="article:author" content={author} />
    )}

    <!-- Favicon -->
    <link rel="icon"             href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Astro SPA transitions -->
    <ClientRouter />

    <style is:global>
      @font-face {
        font-family: 'customfont';
        src: url('/customfont.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      :root {
        --font-sans: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --font-mono: ui-monospace, 'Cascadia Code', 'Fira Code', monospace;
      }
      html {
        font-family: var(--font-sans);
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      html:not(.dark) { background-color: #E8E7E3; }
      html.dark        { background-color: #0a0a0a; }
      body { margin: 0; padding: 0; overflow-x: hidden; }
    </style>
  </head>

  <body>
    <ErrorBoundary>
      <ThemeProvider>
        <slot />
      </ThemeProvider>
    </ErrorBoundary>

    <DevPanelLoader client:only="react" />

    <!-- Re-apply theme after SPA navigation -->
    <script is:inline>
      document.addEventListener('astro:after-swap', function () {
        var t = localStorage.getItem('theme') || 'dark';
        var d = t !== 'light';
        document.documentElement.classList.toggle('dark', d);
        document.documentElement.style.colorScheme = d ? 'dark' : 'light';
        document.documentElement.style.backgroundColor = d ? '#0a0a0a' : '#E8E7E3';
      });
    </script>
  </body>
</html>